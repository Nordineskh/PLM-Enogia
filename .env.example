# ═══════════════════════════════════════════════════════════
# PLM Enogia — Variables d'environnement Firebase
# ═══════════════════════════════════════════════════════════
#
# 1. Copier ce fichier : cp .env.example .env
# 2. Remplir les valeurs depuis Firebase Console
#    → https://console.firebase.google.com
#    → Projet Enogia PLM → Paramètres → Vos applications
# 3. NE JAMAIS committer le fichier .env (il est dans .gitignore)
#
# Pour le déploiement GitHub Pages, ces valeurs sont à ajouter
# dans : Settings → Secrets and variables → Actions
# ═══════════════════════════════════════════════════════════

# Firebase Web API Key
FIREBASE_API_KEY=votre-api-key-ici

# Firebase Auth Domain
FIREBASE_AUTH_DOMAIN=votre-projet.firebaseapp.com

# Firebase Project ID
FIREBASE_PROJECT_ID=votre-project-id

# Firebase Storage Bucket
FIREBASE_STORAGE_BUCKET=votre-projet.appspot.com

# Firebase Messaging Sender ID
FIREBASE_MESSAGING_SENDER_ID=123456789

# Firebase App ID
FIREBASE_APP_ID=1:123456789:web:abcdef123456

# ─── Configuration PLM ──────────────────────────────────────

# Domaine email autorisé (authentification restreinte)
ALLOWED_EMAIL_DOMAIN=enogia.fr

# Environnement (development | staging | production)
APP_ENV=production

# Version de l'application
APP_VERSION=2.4.1
